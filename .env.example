# ============================================================
#  Ahoum Sessions Marketplace — environment variables
#  Copy this file to `.env` and fill in the values:
#      cp .env.example .env
#
#  SECURITY: never commit a real .env. The values below are
#  placeholders. Secrets (OAuth client secrets, DB password,
#  Django secret key) must stay out of version control.
# ============================================================

# --- Public app port (Nginx, local docker-compose only) ---
APP_PORT=80

# --- Database (PostgreSQL) ---
POSTGRES_DB=ahoum
POSTGRES_USER=ahoum
POSTGRES_PASSWORD=change-me-strong-password

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx

# Public URLs (single origin via Nginx locally).
# If APP_PORT != 80, include the port, e.g. http://localhost:8080
FRONTEND_URL=http://localhost
BACKEND_BASE_URL=http://localhost
CORS_ALLOWED_ORIGINS=http://localhost

# --- JWT ---
JWT_ACCESS_MIN=60
JWT_REFRESH_DAYS=7

# --- Rate limiting (bonus) ---
THROTTLE_AUTH=20/min
THROTTLE_BOOKING=30/min

# ============================================================
#  OAuth credentials — create apps in the provider consoles.
#
#  LOCAL (docker-compose) redirect URIs to register:
#    Google: http://localhost/api/auth/google/callback
#    GitHub: http://localhost/api/auth/github/callback
#
#  PRODUCTION (Render) redirect URIs to register:
#    Google: https://ahoum-backend.onrender.com/api/auth/google/callback
#    GitHub: https://ahoum-backend.onrender.com/api/auth/github/callback
#
#  You can register BOTH the local and production callback URLs on the
#  same OAuth app, so one set of credentials works everywhere.
#  On Render, set these four values in the dashboard (not in git).
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Frontend (local non-docker dev only) ---
# When running `npm run dev` outside docker, point the app at the backend:
#   VITE_API_BASE_URL=http://localhost:8000/api
# In docker-compose and on Render this is set for you.
